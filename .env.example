# ── Server (服务运行端口) ──────────────────────────────────────────────
# 保持默认即可，Nginx 会把外部 80/443 请求转发到本地的 3000 端口
# 启动监听端口（默认为 3000）
PORT=3000
# 你的系统名，会在网页引流小尾巴展示
APP_NAME="Your App Name"

# ── Frontend (前端物理路径) ──────────────────────────────────────────────
# 如果 Nginx 不接管前端，这是后端的保底。请填写前端打包后的绝对路径。
# 前端 dist 目录绝对路径，后端需要根据此路径提供静态文件
FRONTEND_DIST_PATH=/opt/MoodSpace-Frontend/dist

# ── Admin Auth (管理员 API 密钥) ───────────────────────────────────────
# 获取/设置位置: 自己随便编一个强密码（比如一串随机的 UUID 或长字符串）。
# ⚠️ 注意: 填好后，必须去 CF Dashboard -> Workers -> moodspace-worker -> Settings -> Variables 里，添加一个同名(ADMIN_KEY)且同值的 Secret！
# 作用: 拦截所有恶意请求，确保只有拥有此密钥的后端才能让 Worker 重绘页面/更新KV。
ADMIN_KEY=your_admin_secret_here

# ── Cloudflare 全局配置 ────────────────────────────────────────────────
# 获取位置: 登录 CF -> 随便点进一个你的域名概览页 -> 右下角找 "Account ID"（账户 ID）
CF_ACCOUNT_ID=your-account-id

# 获取位置: 登录 CF -> 右上角头像 -> My Profile -> API Tokens -> Create Token -> Custom token
# 必须赋予这 2 个细分权限:
# 1. Account -> Workers KV Storage -> Edit
# 2. Zone -> Cache Purge -> Purge
CF_API_TOKEN=your-api-token

# ── Cloudflare Zone (域名区域配置) ─────────────────────────────────────
# 获取位置: 登录 CF -> 点击你需要清理缓存的域名（如 moodspace.xyz）-> 概览页右下角找 "Zone ID"（区域 ID）
# 作用: 当用户修改了页面配置后，后端通过此 ID 调 CF API 秒级刷新该子域名的边缘缓存。
CF_ZONE_ID=your-zone-id

# Cloudflare 解析的主域名名称 (用于拼接内部链接)
CF_ZONE_NAME=moodspace.xyz

# ── Cloudflare KV (轻量级键值存储) ──────────────────────────────────────
# 获取位置: CF 控制台左侧 -> Workers & Pages -> KV -> 找到 MOODSPACE_KV -> 复制一侧的 "Namespace ID"
CF_KV_NAMESPACE_ID=your-kv-namespace-id

# ── Cloudflare R2 (大文件对象存储) ──────────────────────────────────────
# Bucket 名称必须与你在 R2 中创建的名字，以及 wrangler.toml 里的 bucket_name 完全一致
CF_R2_BUCKET=your-r2-bucket-name

# 获取位置: CF 控制台左侧 -> R2 -> 右上角 "Manage R2 API Tokens" -> Create API token
# 权限必须选: "Object Read & Write"
# 生成后页面只会展示一次！请立刻把 Access Key ID 和 Secret Access Key 复制并填在下方：
CF_R2_ACCESS_KEY_ID=your-r2-access-key-id
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# 规则: 格式固定为 https://<你的CF_ACCOUNT_ID>.r2.cloudflarestorage.com
# 只需要把中间的 account-id 换掉即可，不要加末尾斜杠
CF_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# ── Supabase (PostgreSQL 数据库，用于存储用户凭证与积分流) ───────────────
# 获取位置: Supabase 控制台 -> 进入你的项目 -> 左下角 Project Settings -> API
# URL: 在 "Project URL" 下方
SUPABASE_URL=https://your-project.supabase.co
# Key: 在同一页面的 "Project API keys" 下方 -> 找到带有 "service_role" 标签的那串秘钥并复制 (切勿用 anon key)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Template Synchronization (模板读取来源配置) ──────────────────────────
# 你的 GitHub 用户名 (必须)
TEMPLATES_REPO_OWNER=your-github-username

# 承载模板前端代码的 GitHub 仓库名称 (必须)
TEMPLATES_REPO_NAME=your-templates-repo-name

# (可选) GitHub 个人访问令牌
# 获取位置: GitHub -> 右上角头像 -> Settings -> 左下角 Developer settings -> Personal access tokens (classic)
# 作用: GitHub 公开 API 每小时有请求次数限制。如果你在管理后台点击 "同步模板库" 时遇到 `API rate limit exceeded` 报错，就需要申请 Token 填在这里。
# (可选) GitHub 个人访问令牌, 用于突破 API 调用频率限制
# GITHUB_TOKEN=你的github_token_在这里

# (可选) 本地文件路径备份
# 只有当你决定把 MoodSpace-Templates 仓库也 git clone 到 VPS 本地磁盘上时才开启。开启后，后端会优先读本地磁盘模板而不是去 GitHub 现拉。
# (可选) 本地文件路径备份，如果 VPS 存在本地模板库则优先读取
# TEMPLATES_LOCAL_PATH=/opt/MoodSpace-Templates/src

# ── ZhifuFM Payment (支付FM 接口配置 L6.5) ─────────────────────────────
# 支付FM 统一下单接口域名 (不要加斜杠结尾)
ZHIFUFM_API_URL=https://api.zhifux.com
# 你的商户号 (PID)
ZHIFUFM_MERCHANT_NUM=你的商户号_在这里
# 你的通讯密钥 (Secret Key)
ZHIFUFM_SECRET_KEY=你的密钥_在这里

# ── 站点地址 (用于支付回调) ──
APP_BASE_URL=https://api.moodspace.xyz
FRONTEND_URL=https://www.moodspace.xyz

# ── 其他高级功能配置 (Optional) ──────────────────────────────────────────
# Cloudflare 解析的主域名名称 (用于拼接内部链接，如未配置则默认兜底为 moodspace.xyz)
CF_ZONE_NAME=moodspace.xyz

# 生成的模板静态 JSON 缓存文件落地绝对路径 (如果不填，代码会默认降级为 /opt/cache/templates.json)
# STATIC_TEMPLATE_PATH=/opt/cache/templates.json

# 后台 API 的 CORS (跨域资源共享) 允许访问来源白名单。默认 * 代表允许任何人跨域调用 API。
# 生产环境中推荐配置为你的真实前端域名，例: https://www.moodspace.xyz
# ALLOWED_ORIGIN=*